PROJECT_NAME           = "cpp_interface"
PROJECT_BRIEF          = "Embedded R interpreter C++20 API"
OUTPUT_DIRECTORY       = @PROJECT_SOURCE_DIR@/doc
CREATE_SUBDIRS         = NO
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
QUIET                  = YES
RECURSIVE              = NO
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
JAVADOC_AUTOBRIEF      = YES
OPTIMIZE_OUTPUT_FOR_C  = NO
INPUT                  = @PROJECT_SOURCE_DIR@/include/EmbedR.hpp
FILE_PATTERNS          = *.hpp
GENERATE_TREEVIEW      = YES
FULL_PATH_NAMES        = YES
STRIP_FROM_PATH        = @PROJECT_SOURCE_DIR@
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
